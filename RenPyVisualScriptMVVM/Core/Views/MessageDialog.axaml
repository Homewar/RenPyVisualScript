<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RenPyVisualScriptMVVM.Core.ViewModels"
        x:Class="RenPyVisualScriptMVVM.Core.Views.MessageDialog"
        x:DataType="vm:MessageDialogViewModel"
        Width="520" Height="320"
        CanResize="False"
        Background="#1e1e1e"
        Title="{Binding Title}">

  <Grid RowDefinitions="*,Auto" Margin="16" RowSpacing="12">

    <ScrollViewer Grid.Row="0">
      <TextBlock Text="{Binding Message}"
                 Foreground="White"
                 TextWrapping="Wrap" />
    </ScrollViewer>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="OK" Command="{Binding OkCmd}" />
    </StackPanel>

  </Grid>
</Window>
