<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RenPyVisualScriptMVVM.Modules.Editors.Views.EditorMessageDialog"
        Width="520"
        Height="240"
        MinWidth="420"
        MinHeight="180"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e">

  <Grid RowDefinitions="*,Auto" Margin="16" RowSpacing="12">
    <ScrollViewer Grid.Row="0">
      <TextBox x:Name="MessageTextBox"
               IsReadOnly="True"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               Foreground="#d6d6d6"
               Background="#252526"
               BorderBrush="#3c3c3c"/>
    </ScrollViewer>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Content="Copy"
              Width="90"
              Click="Copy_OnClick"/>
      <Button Content="OK"
              Width="90"
              IsDefault="True"
              Click="Ok_OnClick"/>
    </StackPanel>
  </Grid>
</Window>
