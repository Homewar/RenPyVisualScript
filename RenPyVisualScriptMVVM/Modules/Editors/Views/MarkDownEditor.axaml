<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
		xmlns:vm="using:RenPyVisualScriptMVVM.Modules.Editors.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RenPyVisualScriptMVVM.Modules.Editors.Views.MarkDownEditor"
        Title="MarkDownEditor">
	
	<UserControl.DataContext>
		<vm:MarkDownEditorViewModel/>
	</UserControl.DataContext>

	<md:MarkdownScrollViewer DragDrop.AllowDrop="True" />
</UserControl>
