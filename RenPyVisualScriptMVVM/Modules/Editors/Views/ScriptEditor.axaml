<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:cp="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
		xmlns:prims="clr-namespace:Avalonia.Controls.Primitives;assembly=Avalonia.Controls.ColorPicker"
		xmlns:vm="using:RenPyVisualScriptMVVM.Modules.Editors.ViewModels"
		xmlns:models="using:RenPyVisualScriptMVVM.Modules.Editors.Models"
		xmlns:conv="using:RenPyVisualScriptMVVM.Modules.Editors.ViewModels"
        xmlns:dock="clr-namespace:Dock.Model.Mvvm.Controls;assembly=Dock.Model.Mvvm"
        xmlns:dockMvvm="clr-namespace:Dock.Model.Mvvm;assembly=Dock.Model.Mvvm"
		xmlns:views="using:RenPyVisualScriptMVVM.Modules.Editors.Views"
		xmlns:local="clr-namespace:RenPyVisualScriptMVVM.Modules.Editors.Views"
		mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="RenPyVisualScriptMVVM.Modules.Editors.Views.ScriptEditor"
		x:DataType="vm:ScriptEditorViewModel"
		RequestedThemeVariant="Dark"
		Background="#1e1e1e"
		Title="{Binding ProjectName}"
		>
	
	<Window.Resources>
		<conv:StringToBrushConverter x:Key="StrToBrush"/>
	</Window.Resources>


	<Grid ShowGridLines="False">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="Auto" MinWidth="300" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="30"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		
		<Border BorderBrush="#ea592a" BorderThickness="0,0,0,2" Grid.Row="0">
		<StackPanel Orientation="Horizontal" Grid.Column="0">
			<DockPanel>
				<Menu DockPanel.Dock="Top">
					<MenuItem Header="File">
						<MenuItem Header="Save Project" Command="{Binding SaveCmd}"/>
					</MenuItem>
					<MenuItem Header="Menu">
					</MenuItem>
					<MenuItem Header="Project">
						<MenuItem Header="Project Settings" Command="{Binding ShowProjectSetCmd}"/>
						<MenuItem Header="GUI Settings" Command="{Binding ShowAppSettingsCmd}"/>
					</MenuItem>
					<MenuItem Header="Addon">	
					</MenuItem>
					<MenuItem Header="Comming Soon">
					</MenuItem>
				</Menu>
			</DockPanel>
		</StackPanel>
		</Border>
		<Border BorderBrush="#ea592a" BorderThickness="0,0,0,2" Grid.Column="2">
		<StackPanel Orientation="Horizontal" Grid.Column="2" HorizontalAlignment="Right">
			<Button Content="Run" Command="{Binding RunProjectCmd}" Margin="0,0,6,0"/>
			<Button Content=""/>
		</StackPanel>
		</Border>
		<GridSplitter Grid.Row="1" Grid.Column="1" ResizeDirection="Columns" 
					  Margin="0,-1,3,0" ResizeBehavior="PreviousAndNext" 
					  Background="#EA592A"/>
		
		
		<Grid Grid.Row="1" Grid.Column="2"  ShowGridLines="True">
			<TabControl>
				<TabItem Header="source">
			<Grid Grid.Row="1" ShowGridLines="False">
				<Grid.RowDefinitions>
					<RowDefinition Height="0.3*"/>
					<RowDefinition Height="0.3*"/>
					<RowDefinition Height="0.3*"/>
				</Grid.RowDefinitions>
				
				<!-- 1-й список -->
				<StackPanel Grid.Row="0" Margin="0,0,0,2">
					<Grid ColumnDefinitions="*,auto">
						<TextBlock Grid.Column="0" Text="Characters Define" FontSize="14" 
								   Foreground="#d6d6d6" Background="#2d2d30"
								   Padding="5,5,0,0"
								   HorizontalAlignment="Stretch"/>
						<Button Grid.Column="1" HorizontalAlignment="Right" Background="#EA592A">+</Button>
					</Grid>
					<ScrollViewer Grid.Row="0" VerticalAlignment="Stretch" MaxHeight="350">
					<ListBox ItemsSource="{Binding CharacterList}" VerticalAlignment="Stretch" Background="#252526">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Grid ColumnDefinitions="*,*,*" RowDefinitions="*,Auto">
									<Rectangle Grid.Row="1" />
									<TextBlock Grid.Column="0" Margin="0,0,5,0" Text="{Binding Name}"/>
									<ColorPicker Grid.Column="1" MaxHeight="18" />
									<TextBlock Grid.Column="2" Margin="0,0,5,0" Text="{Binding InGameName}"/>
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</ScrollViewer>
				</StackPanel>
				
				<!-- 2-й список -->
				<StackPanel Grid.Row="1" Margin="0,0,0,2">
					<Grid ColumnDefinitions="*,auto">
						<TextBlock Grid.Column="0" Text="Characters Define" FontSize="14"
								   Foreground="White" Background="#2d2d30"
								   Padding="5,5,0,0"
								   HorizontalAlignment="Stretch"/>
						<Button Background="#EA592A" Grid.Column="1" HorizontalAlignment="Right">+</Button>
					</Grid>
				<ScrollViewer Grid.Row="1" VerticalAlignment="Stretch" MaxHeight="350">
					<ListBox ItemsSource="{Binding CharacterList}" Background="#252526">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Grid ColumnDefinitions="*,*,*">
									<TextBlock Grid.Column="0" Margin="0,0,5,0" Text="{Binding Name}"/>
									<ColorPicker Grid.Column="1" MaxHeight="18" />
									<TextBlock Grid.Column="2" Margin="0,0,5,0" Text="{Binding InGameName}"/>
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</ScrollViewer>
				</StackPanel>
				
				<!-- 3-й список -->
				<StackPanel Grid.Row="2" Margin="0,0,0,2">
					<Grid ColumnDefinitions="*,auto">
						<TextBlock Grid.Column="0" Text="Characters Define" FontSize="14"
								   Foreground="#d6d6d6" Background="#2d2d30"
								   Padding="5,5,0,0"
								   HorizontalAlignment="Stretch"/>
						<Button Background="#EA592A" Grid.Column="1" HorizontalAlignment="Right">+</Button>
					</Grid>
				<ScrollViewer Grid.Row="2" MaxHeight="350">
					<ListBox ItemsSource="{Binding CharacterList}" Background="#252526">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Grid ColumnDefinitions="*,*,*">
									<TextBlock Grid.Column="0" Margin="0,0,5,0" Text="{Binding Name}"/>
									<ColorPicker Grid.Column="1" MaxHeight="18" Color="{Binding Color}"/>
									<TextBlock Grid.Column="2" Margin="0,0,5,0" Text="{Binding InGameName}"/>
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</ScrollViewer>
				</StackPanel>
				
			</Grid>
				</TabItem>
				<TabItem Header="files">
					<Grid>
						<TreeView ItemsSource="{Binding FileTreeNodes}" Margin="10" SelectedItem="{Binding SelectedFileNode,Mode=TwoWay}">
							<TreeView.ItemTemplate>
								<TreeDataTemplate ItemsSource="{Binding Children}">
									<TextBlock Text="{Binding Name}"/>
								</TreeDataTemplate>
							</TreeView.ItemTemplate>
						</TreeView>
					</Grid>
				</TabItem>
			</TabControl>
		</Grid>

		<TabControl Grid.Row="1" Grid.Column="0"
			ItemsSource="{Binding Tabs}"
			SelectedItem="{Binding SelectedTab, Mode=TwoWay}">

			<TabControl.ItemTemplate>
				<DataTemplate x:DataType="models:TabItemModel">
					<DockPanel LastChildFill="False" Margin="0,0,4,0">
						<TextBlock Text="{Binding Header}"
								   VerticalAlignment="Center"
								   Margin="4,0"
								   DockPanel.Dock="Left"/>
						<Button Content="✕" BorderThickness="0,-7,0,0"
								VerticalAlignment="Center"
								HorizontalAlignment="Center"
								Width="20" Height="20"
								Padding="0"
								Command="{Binding CloseCommand}"/>
					</DockPanel>
				</DataTemplate>
			</TabControl.ItemTemplate>
			
			<TabControl.ContentTemplate>
				<DataTemplate x:DataType="models:TabItemModel">
					<local:AvaloniaEdit FilePath="{Binding FilePath}"/>
				</DataTemplate>
			</TabControl.ContentTemplate>
		</TabControl>
	</Grid>
</Window>
