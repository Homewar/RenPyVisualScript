<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:RenPyVisualScriptMVVM.Modules.Editors.ViewModels"
        xmlns:models="using:RenPyVisualScriptMVVM.Modules.Editors.Models"
        xmlns:conv="using:RenPyVisualScriptMVVM.Modules.Editors.ViewModels"
        xmlns:core="using:RenPyVisualScriptMVVM.Core.Models"
        xmlns:local="clr-namespace:RenPyVisualScriptMVVM.Modules.Editors.Views"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="RenPyVisualScriptMVVM.Modules.Editors.Views.ScriptEditor"
        x:DataType="vm:ScriptEditorViewModel"
        RequestedThemeVariant="Dark"
        Background="#1e1e1e"
        Title="{Binding ProjectName}">

    <Window.Resources>
        <conv:StringToBrushConverter x:Key="StrToBrush"/>
    </Window.Resources>

    <Grid ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto" MinWidth="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#ea592a" BorderThickness="0,0,0,2" Grid.Row="0">
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <DockPanel>
                    <Menu DockPanel.Dock="Top">
                        <MenuItem Header="File">
                            <MenuItem Header="Save Project" Command="{Binding SaveCmd}"/>
                        </MenuItem>
                        <MenuItem Header="Menu"/>
                        <MenuItem Header="Project">
                            <MenuItem Header="Project Settings" Command="{Binding ShowProjectSetCmd}"/>
                            <MenuItem Header="GUI Settings" Command="{Binding ShowAppSettingsCmd}"/>
                            <MenuItem Header="IDE Settings" Command="{Binding ShowIdeSettingsCmd}"/>
                        </MenuItem>
                        <MenuItem Header="Addon">
                            <MenuItem Header="Open Graph Editor" Command="{Binding OpenGraphCmd}"/>
                        </MenuItem>
                        <MenuItem Header="Comming Soon"/>
                    </Menu>
                </DockPanel>
            </StackPanel>
        </Border>

        <Border BorderBrush="#ea592a" BorderThickness="0,0,0,2" Grid.Column="2">
            <StackPanel Orientation="Horizontal" Grid.Column="2" HorizontalAlignment="Right">
                <Button Content="Run" Command="{Binding RunProjectCmd}" Margin="0,0,6,0"/>
                <Button Content="Run Here" Command="{Binding RunFromHereCmd}" Margin="0,0,6,0"/>
                <Button Content="Graph" Command="{Binding OpenGraphCmd}" Margin="0,0,6,0"/>
                <Button Content="Refresh" Command="{Binding RefreshStructureCmd}" Margin="0,0,6,0"/>
            </StackPanel>
        </Border>

        <GridSplitter Grid.Row="1" Grid.Column="1" ResizeDirection="Columns"
                      Margin="0,-1,3,0" ResizeBehavior="PreviousAndNext"
                      Background="#EA592A"/>

        <Grid Grid.Row="1" Grid.Column="2">
            <TabControl>
                <TabItem Header="source">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#2d2d30" Padding="8" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <TextBlock Text="{Binding StructureSummary}" Foreground="#d6d6d6" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshStructureCmd}" Background="#EA592A"/>
                            </DockPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" Margin="0,8,0,0">
                            <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                                <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                                <Expander.Header>
                                    <TextBlock Text="Characters" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                                </Expander.Header>
                                <ListBox ItemsSource="{Binding CharacterList}" Background="Transparent" BorderThickness="0" DoubleTapped="CharacterList_OnDoubleTapped">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="core:Character">
                                            <Grid ColumnDefinitions="16,*,Auto" Margin="8,4">
                                                <Border Width="12" Height="12" CornerRadius="6"
                                                        Background="{Binding Color, Converter={StaticResource StrToBrush}}"
                                                        VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding Name}"/>
                                                    <TextBlock Text="{Binding InGameName}" Foreground="#9cdcfe" FontSize="11"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Color}" Foreground="#808080" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding Line, StringFormat='{}line {0}'}" Foreground="#808080" FontSize="11" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                </Expander>

                                <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                                <Expander.Header>
                                    <TextBlock Text="Labels" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                                </Expander.Header>
                                <ListBox ItemsSource="{Binding LabelList}" Background="Transparent" BorderThickness="0" DoubleTapped="LabelList_OnDoubleTapped">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:LabelOutlineItem">
                                            <Grid ColumnDefinitions="*,Auto" Margin="8,4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"/>
                                                    <TextBlock Text="{Binding FilePath}" Foreground="#808080" FontSize="11"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding StatementCount, StringFormat='{}{0} stmts'}" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding Line, StringFormat='{}line {0}'}" Foreground="#808080" FontSize="11" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                </Expander>

                                <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                                <Expander.Header>
                                    <TextBlock Text="Links and choices" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                                </Expander.Header>
                                <ListBox ItemsSource="{Binding TransitionItems}" Background="Transparent" BorderThickness="0" DoubleTapped="TransitionItems_OnDoubleTapped">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:TransitionPanelItem">
                                            <Border Margin="8,4" Padding="8" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="6">
                                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                                    <Border Background="#3c3c3c" Padding="6,2" CornerRadius="4" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding Kind}" FontSize="11"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Description}"/>
                                                        <TextBlock Text="{Binding Source, StringFormat='{}from {0}'}" Foreground="#9cdcfe" FontSize="11"/>
                                                        <TextBlock Text="{Binding Target, StringFormat='{}target {0}'}" Foreground="#808080" FontSize="11" IsVisible="{Binding ShowTarget}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding FileName}" Foreground="#808080" FontSize="11" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding Line, StringFormat='{}line {0}'}" Foreground="#808080" FontSize="11" HorizontalAlignment="Right"/>
                                                    </StackPanel>

                                                    <ItemsControl Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" ItemsSource="{Binding Choices}" IsVisible="{Binding IsMenuGroup}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:StructureLinkItem">
                                                                <Border Margin="0,4,0,0" Padding="8,6" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="4" DoubleTapped="TransitionChoice_OnDoubleTapped">
                                                                    <Grid ColumnDefinitions="*,Auto">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Description}" />
                                                                            <TextBlock Text="{Binding Target, StringFormat='{}target {0}'}" Foreground="#808080" FontSize="11"/>
                                                                        </StackPanel>
                                                                        <TextBlock Grid.Column="1" Text="{Binding Line, StringFormat='{}line {0}'}" Foreground="#808080" FontSize="11" VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
                <TabItem Header="files">
                    <Grid>
                        <TreeView ItemsSource="{Binding FileTreeNodes}" Margin="10" SelectedItem="{Binding SelectedFileNode,Mode=TwoWay}">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Name}"/>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </TabItem>
                <TabItem Header="resources">
                    <ScrollViewer Margin="0,8,0,0">
                        <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                            <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock Text="Images" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                            </Expander.Header>
                            <ListBox ItemsSource="{Binding ImageResources}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:ResourceFileItem">
                                        <Grid ColumnDefinitions="*,Auto" Margin="8,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"/>
                                                <TextBlock Text="{Binding RelativePath}" Foreground="#808080" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Extension}" Foreground="#9cdcfe" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            </Expander>

                            <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock Text="Music and audio" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                            </Expander.Header>
                            <ListBox ItemsSource="{Binding AudioResources}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:ResourceFileItem">
                                        <Grid ColumnDefinitions="*,Auto" Margin="8,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"/>
                                                <TextBlock Text="{Binding RelativePath}" Foreground="#808080" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Extension}" Foreground="#9cdcfe" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            </Expander>

                            <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock Text="Video" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                            </Expander.Header>
                            <ListBox ItemsSource="{Binding VideoResources}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:ResourceFileItem">
                                        <Grid ColumnDefinitions="*,Auto" Margin="8,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"/>
                                                <TextBlock Text="{Binding RelativePath}" Foreground="#808080" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Extension}" Foreground="#9cdcfe" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <TabControl Grid.Row="1" Grid.Column="0"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab, Mode=TwoWay}">

            <TabControl.ItemTemplate>
                <DataTemplate x:DataType="models:TabItemModel">
                    <DockPanel LastChildFill="False" Margin="0,0,4,0">
                        <TextBlock Text="{Binding Header}"
                                   VerticalAlignment="Center"
                                   Margin="4,0"
                                   DockPanel.Dock="Left"/>
                        <Button Content="✕" BorderThickness="0,-7,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Width="20" Height="20"
                                Padding="0"
                                Command="{Binding CloseCommand}"/>
                    </DockPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate x:DataType="models:TabItemModel">
                    <local:AvaloniaEdit FilePath="{Binding FilePath}"
                                        TargetLine="{Binding TargetLine}"
                                        NavigationRequestId="{Binding NavigationRequestId}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</Window>
