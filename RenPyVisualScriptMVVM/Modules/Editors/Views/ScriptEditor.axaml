<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:RenPyVisualScriptMVVM.Modules.Editors.ViewModels"
        xmlns:models="using:RenPyVisualScriptMVVM.Modules.Editors.Models"
        xmlns:conv="using:RenPyVisualScriptMVVM.Modules.Editors.ViewModels"
        xmlns:core="using:RenPyVisualScriptMVVM.Core.Models"
        xmlns:local="clr-namespace:RenPyVisualScriptMVVM.Modules.Editors.Views"
        xmlns:editConv="using:RenPyVisualScriptMVVM.Modules.Editors.Converters"
        xmlns:editCtrl="using:RenPyVisualScriptMVVM.Modules.Editors.Controls"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="RenPyVisualScriptMVVM.Modules.Editors.Views.ScriptEditor"
        x:DataType="vm:ScriptEditorViewModel"
        RequestedThemeVariant="Dark"
        Background="{StaticResource EditorBackgroundBrush}"
        Title="{Binding ProjectName}">

    <Window.Resources>
        <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#1e1e1e"/>
        <SolidColorBrush x:Key="ActivityBarBackgroundBrush" Color="#181818"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#252526"/>
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#2d2d30"/>
        <SolidColorBrush x:Key="PreviewBackgroundBrush" Color="#1b1b1c"/>
        <SolidColorBrush x:Key="PreviewSurfaceBrush" Color="#202022"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3c3c3c"/>
        <SolidColorBrush x:Key="SubtleBorderBrush" Color="#2a2a2a"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#ea592a"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#d6d6d6"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8f8f8f"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#b8b8b8"/>
        <SolidColorBrush x:Key="IconTextBrush" Color="#d0d0d0"/>
        <SolidColorBrush x:Key="InfoTextBrush" Color="#9cdcfe"/>
        <conv:StringToBrushConverter x:Key="StrToBrush"/>
        <editConv:ImagePreviewConverter x:Key="ImagePreviewConverter"/>
        <editConv:VideoPreviewConverter x:Key="VideoPreviewConverter"/>
        <editConv:FontPreviewConverter x:Key="FontPreviewConverter"/>
    </Window.Resources>

    <Grid ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="52"/>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="360" MinWidth="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2" Grid.Row="0" Grid.Column="1">
            <StackPanel Orientation="Horizontal">
                <DockPanel>
                    <Menu DockPanel.Dock="Top">
                        <MenuItem Header="File">
                            <MenuItem Header="Save Project" Command="{Binding SaveCmd}"/>
                        </MenuItem>
                        <MenuItem Header="Menu"/>
                        <MenuItem Header="Project">
                            <MenuItem Header="Project Settings" Command="{Binding ShowProjectSetCmd}"/>
                            <MenuItem Header="GUI Settings" Command="{Binding ShowAppSettingsCmd}"/>
                            <MenuItem Header="IDE Settings" Command="{Binding ShowIdeSettingsCmd}"/>
                        </MenuItem>
                        <MenuItem Header="Addon">
                            <MenuItem Header="Open Graph Editor" Command="{Binding OpenGraphCmd}"/>
                        </MenuItem>
                        <MenuItem Header="Comming Soon"/>
                    </Menu>
                </DockPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="3" BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding StartPointText}" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource PrimaryTextBrush}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{StaticResource ActivityBarBackgroundBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,10,0,0"
                        Spacing="8">
                <Button Width="36"
                        Height="36"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{Binding RunProjectCmd}"
                        ToolTip.Tip="{Binding RunButtonText}">
                    <Grid Width="26" Height="26">
                        <Image x:Name="RunActivityIcon"
                               Width="26"
                               Height="26"
                               IsVisible="False"/>
                        <TextBlock x:Name="RunActivityFallback"
                                   Text="▶"
                                   FontSize="22"
                                   Foreground="{StaticResource IconTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Width="36"
                        Height="36"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{Binding OpenGraphCmd}"
                        ToolTip.Tip="Open Graph">
                    <Grid Width="26" Height="26">
                        <Image x:Name="GraphActivityIcon"
                               Width="26"
                               Height="26"
                               IsVisible="False"
                               Source="avares://RenPyVisualScriptMVVM/Assets/Icons/graph_editor.png"
                               />
                        <TextBlock x:Name="GraphActivityFallback"
                                   Text="◫"
                                   FontSize="21"
                                   Foreground="{StaticResource IconTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </StackPanel>
        </Border>

        <GridSplitter Grid.Row="1" Grid.Column="2" ResizeDirection="Columns"
                      Margin="0,-1,3,0" ResizeBehavior="PreviousAndNext"
                      Background="{StaticResource AccentBrush}"/>

        <Grid Grid.Row="1" Grid.Column="3">
            <TabControl>
                <TabItem Header="source" FontSize="16">
                    <Grid Margin="0">
                        <ScrollViewer Margin="0,8,0,0"
                                      Padding="0,0,12,0">
                            <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                                <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                                <Expander.Header>
                                    <DockPanel Margin="8,6">
                                        <Button DockPanel.Dock="Right"
                                                Content="Add"
                                                Click="CreateCharacter_OnClick"
                                                Padding="10,2"
                                                Margin="8,0,0,0"/>
                                        <TextBlock Text="{Binding CharacterList.Count, StringFormat='Characters ({0})'}" FontSize="14" Foreground="#d6d6d6" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Expander.Header>
                                <ListBox ItemsSource="{Binding CharacterList}" Background="Transparent" BorderThickness="0" DoubleTapped="CharacterList_OnDoubleTapped">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="core:Character">
                                            <Grid ColumnDefinitions="16,*,Auto" Margin="8,4">
                                                <Border Width="12" Height="12" CornerRadius="6"
                                                        Background="{Binding Color, Converter={StaticResource StrToBrush}}"
                                                        VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="14"/>
                                                    <TextBlock Text="{Binding InGameName}" Foreground="#9cdcfe" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Color}" Foreground="#808080" HorizontalAlignment="Right" FontSize="12"/>
                                                    <TextBlock Text="{Binding Line, StringFormat='{}line {0}'}" Foreground="#808080" FontSize="12" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                </Expander>

                                <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                                <Expander.Header>
                                    <TextBlock Text="{Binding LabelList.Count, StringFormat='Labels ({0})'}" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                                </Expander.Header>
                                <ListBox ItemsSource="{Binding LabelList}" Background="Transparent" BorderThickness="0" DoubleTapped="LabelList_OnDoubleTapped">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:LabelOutlineItem">
                                            <Grid ColumnDefinitions="*,Auto" Margin="8,4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="14"/>
                                                    <TextBlock Text="{Binding FilePath}" Foreground="#808080" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding StatementCount, StringFormat='{}{0} stmts'}" HorizontalAlignment="Right" FontSize="12"/>
                                                    <TextBlock Text="{Binding Line, StringFormat='{}line {0}'}" Foreground="#808080" FontSize="12" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                </Expander>

                                <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                                <Expander.Header>
                                    <TextBlock Text="{Binding TransitionItems.Count, StringFormat='Links and choices ({0})'}" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                                </Expander.Header>
                                <ListBox ItemsSource="{Binding TransitionItems}" Background="Transparent" BorderThickness="0" DoubleTapped="TransitionItems_OnDoubleTapped">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:TransitionPanelItem">
                                            <Border Margin="8,4" Padding="8" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="6">
                                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                                    <Border Background="#3c3c3c" Padding="6,2" CornerRadius="4" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding Kind}" FontSize="11"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Description}" FontSize="14"/>
                                                        <TextBlock Text="{Binding Source, StringFormat='{}from {0}'}" Foreground="#9cdcfe" FontSize="12"/>
                                                        <TextBlock Text="{Binding Target, StringFormat='{}target {0}'}" Foreground="#808080" FontSize="12" IsVisible="{Binding ShowTarget}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding FileName}" Foreground="#808080" FontSize="12" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding Line, StringFormat='{}line {0}'}" Foreground="#808080" FontSize="12" HorizontalAlignment="Right"/>
                                                    </StackPanel>

                                                    <ItemsControl Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" ItemsSource="{Binding Choices}" IsVisible="{Binding IsMenuGroup}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:StructureLinkItem">
                                                                <Border Margin="0,4,0,0" Padding="8,6" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="4" DoubleTapped="TransitionChoice_OnDoubleTapped">
                                                                    <Grid ColumnDefinitions="*,Auto">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Description}" FontSize="14"/>
                                                                            <TextBlock Text="{Binding Target, StringFormat='{}target {0}'}" Foreground="#808080" FontSize="12"/>
                                                                        </StackPanel>
                                                                        <TextBlock Grid.Column="1" Text="{Binding Line, StringFormat='{}line {0}'}" Foreground="#808080" FontSize="12" VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
                <TabItem Header="files" FontSize="16">
                    <Grid>
                        <TreeView ItemsSource="{Binding FileTreeNodes}"
                                  Margin="10,10,18,10"
                                  SelectedItem="{Binding SelectedFileNode,Mode=TwoWay}"
                                  KeyDown="FileTree_OnKeyDown">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron">
                                    <Setter Property="Width" Value="10"/>
                                    <Setter Property="Height" Value="10"/>
                                    <Setter Property="Margin" Value="0,0,2,0"/>
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <Border Background="Transparent"
                                            HorizontalAlignment="Stretch"
                                            Padding="4,2"
                                            PointerPressed="FileNode_OnPointerPressed"
                                            PointerMoved="FileNode_OnPointerMoved"
                                            DragDrop.AllowDrop="True"
                                            DragDrop.DragOver="FileNode_OnDragOver"
                                            DragDrop.Drop="FileNode_OnDrop">
                                        <Border.ContextMenu>
                                            <ContextMenu Opened="FileNodeContextMenu_OnOpened">
                                                <MenuItem Header="New File" Click="CreateFile_OnClick"/>
                                                <MenuItem Header="New Folder" Click="CreateFolder_OnClick"/>
                                                <MenuItem Header="Rename" Click="RenameFile_OnClick"/>
                                                <MenuItem Header="Delete" Click="DeleteFile_OnClick"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid ColumnDefinitions="*,Auto"
                                              HorizontalAlignment="Stretch">
                                            <TextBlock Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"
                                                       Foreground="#b8b8b8"
                                                       FontSize="13"/>
                                        </Grid>
                                    </Border>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </TabItem>
                <TabItem Header="resources" FontSize="16">
                    <ScrollViewer Margin="0,8,0,0"
                                  Padding="0,0,12,0">
                        <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                            <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock Text="{Binding ImageResources.Count, StringFormat='Images ({0})'}" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                            </Expander.Header>
                            <ListBox ItemsSource="{Binding ImageResources}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:ResourceFileItem">
                                        <Border Margin="8,4" Padding="6,4" Background="Transparent">
                                            <ToolTip.Tip>
                                                <Border Background="#1b1b1c" BorderBrush="#3c3c3c" BorderThickness="1" Padding="10" MaxWidth="420">
                                                    <StackPanel Spacing="8">
                                                        <editCtrl:AnimatedImagePreview FilePath="{Binding FullPath}"
                                                                                    MaxWidth="360"
                                                                                    MaxHeight="220"
                                                                                    Stretch="Uniform"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="#d6d6d6"/>
                                                        <TextBlock Text="{Binding RelativePath}" Foreground="#808080" FontSize="11" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </ToolTip.Tip>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="14"/>
                                                    <TextBlock Text="{Binding RelativePath}" Foreground="#808080" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Extension}" Foreground="#9cdcfe" VerticalAlignment="Center" FontSize="12"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            </Expander>

                            <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock Text="{Binding AudioResources.Count, StringFormat='Music and audio ({0})'}" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                            </Expander.Header>
                            <ListBox ItemsSource="{Binding AudioResources}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:ResourceFileItem">
                                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="8,4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="14"/>
                                                    <TextBlock Text="{Binding RelativePath}" Foreground="#808080" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Extension}" Foreground="#9cdcfe" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                                <Button Content="▶"
                                                        Click="AudioPlay_OnClick"
                                                        Padding="8,2"
                                                        FontSize="14"
                                                        ToolTip.Tip="Play / Pause"/>
                                                <Button Content="■"
                                                        Click="AudioStop_OnClick"
                                                        Padding="8,2"
                                                        FontSize="14"
                                                        ToolTip.Tip="Stop"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            </Expander>

                            <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock Text="{Binding VideoResources.Count, StringFormat='Video ({0})'}" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                            </Expander.Header>
                            <ListBox ItemsSource="{Binding VideoResources}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:ResourceFileItem">
                                        <Border Margin="8,4" Padding="6,4" Background="Transparent">
                                            <ToolTip.Tip>
                                                <Border Background="#1b1b1c" BorderBrush="#3c3c3c" BorderThickness="1" Padding="10" MaxWidth="480">
                                                    <StackPanel Spacing="8">
                                                        <editCtrl:VideoThumbnailPreview FilePath="{Binding FullPath}"
                                                                                     Width="400"
                                                                                     Height="225"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="#d6d6d6"/>
                                                        <TextBlock Text="{Binding RelativePath}" Foreground="#808080" FontSize="11" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </ToolTip.Tip>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="14"/>
                                                    <TextBlock Text="{Binding RelativePath}" Foreground="#808080" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Extension}" Foreground="#9cdcfe" VerticalAlignment="Center" FontSize="12"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            </Expander>

                            <Expander IsExpanded="True" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" HorizontalAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock Text="{Binding FontResources.Count, StringFormat='Fonts ({0})'}" FontSize="14" Foreground="#d6d6d6" Margin="8,6"/>
                            </Expander.Header>
                            <ListBox ItemsSource="{Binding FontResources}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:ResourceFileItem">
                                        <Grid ColumnDefinitions="*,Auto" Margin="8,4">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Name}" FontSize="14"/>
                                                <Border Background="#202022" BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="4" Padding="8,6">
                                                    <Image Source="{Binding FullPath, Converter={StaticResource FontPreviewConverter}}"
                                                           Height="42"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Left"/>
                                                </Border>
                                                <TextBlock Text="{Binding RelativePath}" Foreground="#808080" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Extension}" Foreground="#9cdcfe" VerticalAlignment="Center" FontSize="12"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <TabControl Grid.Row="1" Grid.Column="1"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab, Mode=TwoWay}">

            <TabControl.ItemTemplate>
                <DataTemplate x:DataType="models:TabItemModel">
                    <DockPanel LastChildFill="False" Margin="0,0,4,0">
                        <TextBlock Text="{Binding Header}"
                                   VerticalAlignment="Center"
                                   Margin="4,0"
                                   DockPanel.Dock="Left"/>
                        <Button Content="✕" BorderThickness="0,-7,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Width="20" Height="20"
                                Padding="0"
                                Command="{Binding CloseCommand}"/>
                    </DockPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate x:DataType="models:TabItemModel">
                    <local:AvaloniaEdit FilePath="{Binding FilePath}"
                                        TargetLine="{Binding TargetLine}"
                                        NavigationRequestId="{Binding NavigationRequestId}"
                                        ReloadRequestId="{Binding ReloadRequestId}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</Window>
