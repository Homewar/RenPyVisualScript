<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:RenPyVisualScriptMVVM.Modules.GraphEditor.Controls"
        xmlns:models="using:RenPyVisualScriptMVVM.Modules.GraphEditor.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RenPyVisualScriptMVVM.Modules.GraphEditor.Views.GraphEditorWindow"
        Background="#1e1e1e"
        Title="Graph Editor">
    <Window.Styles>
        <Style Selector="TextBox.route-input">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#F3F3F3"/>
            <Setter Property="CaretBrush" Value="#F3F3F3"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
        </Style>
        <Style Selector="TextBox.route-input /template/ Border#borderElement">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
        </Style>
        <Style Selector="TextBox.route-input:pointerover">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
        </Style>
        <Style Selector="TextBox.route-input:pointerover /template/ Border#borderElement">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
        </Style>
        <Style Selector="TextBox.route-input:focus">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#EA592A"/>
        </Style>
        <Style Selector="TextBox.route-input:focus /template/ Border#borderElement">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#EA592A"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#F3F3F3"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#F3F3F3"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="#252526"/>
        </Style>
        <Style Selector="TextBox.route-input:focus-within /template/ Border#PART_BorderElement">
			<Setter Property="Background">
                <SolidColorBrush Color="#1e1e1e"/>
            </Setter>
        </Style>
        <Style Selector="TextBox.note-editor">
            <Setter Property="Background" Value="#F3D36B"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Black"/>
            <Setter Property="BorderBrush" Value="#8F6A00"/>
        </Style>
        <Style Selector="TextBox.note-editor /template/ Border#borderElement">
            <Setter Property="Background" Value="#F3D36B"/>
            <Setter Property="BorderBrush" Value="#8F6A00"/>
        </Style>
        <Style Selector="TextBox.note-editor:pointerover">
            <Setter Property="Background" Value="#F3D36B"/>
            <Setter Property="BorderBrush" Value="#8F6A00"/>
        </Style>
        <Style Selector="TextBox.note-editor:pointerover /template/ Border#borderElement">
            <Setter Property="Background" Value="#F3D36B"/>
            <Setter Property="BorderBrush" Value="#8F6A00"/>
        </Style>
        <Style Selector="TextBox.note-editor:focus">
            <Setter Property="Background" Value="#F3D36B"/>
            <Setter Property="BorderBrush" Value="#6F5200"/>
        </Style>
        <Style Selector="TextBox.note-editor:focus /template/ Border#borderElement">
            <Setter Property="Background" Value="#F3D36B"/>
            <Setter Property="BorderBrush" Value="#6F5200"/>
        </Style>
        <Style Selector="TextBox.note-editor:focus-within /template/ Border#PART_BorderElement">
			<Setter Property="Background">
                <SolidColorBrush Color="#F3D36B"/>
            </Setter>
        </Style>
    </Window.Styles>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#252526" Padding="12,8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <TextBlock x:Name="StatsTextBlock" Grid.Column="1" VerticalAlignment="Center" Foreground="#E6E6E6" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <Grid ColumnDefinitions="*,Auto,280">
            <controls:GraphCanvas x:Name="GraphCanvas" Grid.Column="0" Margin="0" />

            <GridSplitter Grid.Column="1"
                          Width="4"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Background="#EA592A"/>

            <Border Grid.Column="2"
                    Background="#252526"
                    BorderBrush="#3C3C3C"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <Grid RowDefinitions="Auto,*,Auto,*" RowSpacing="10">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Routes"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#E6E6E6"/>
                        <Button Grid.Column="1"
                                Content="Clear"
                                Click="OnClearRouteHighlightClick"/>
                    </Grid>

                    <ListBox x:Name="RoutesListBox"
                             Grid.Row="1"
                             Background="#1E1E1E"
                             Foreground="#F3F3F3"
                             BorderBrush="#3C3C3C"
                             BorderThickness="1"
                             MinHeight="120"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:StoryRoute">
                                <Grid ColumnDefinitions="*,Auto" Margin="6,4" Background="Transparent">
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Rename"
                                                      CommandParameter="{Binding}"
                                                      Click="OnRenameRouteMenuItemClick"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#F3F3F3"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding NodeTitles.Count, StringFormat='{}{0} labels'}"
                                               Foreground="#AFAFAF"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="Labels In Selected Route"
                               Grid.Row="2"
                               Margin="0,6,0,0"
                               Foreground="#E6E6E6"
                               FontWeight="SemiBold"/>
                    <ListBox x:Name="RouteNodesListBox"
                             Grid.Row="3"
                             Background="#1E1E1E"
                             Foreground="#F3F3F3"
                             BorderBrush="#3C3C3C"
                             BorderThickness="1"
                             MinHeight="120"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Margin="6,4"
                                           Foreground="#F3F3F3"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
