<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:RenPyVisualScriptMVVM.Modules.Projects.ViewModels"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
        x:Class="RenPyVisualScriptMVVM.Modules.Projects.Views.ProjectSelector"
        x:DataType="vm:ProjectSelectorViewModel"
        Title="Выбор проекта"
        WindowStartupLocation="CenterScreen">

    <Border Background="#2b2b2b" Padding="16" CornerRadius="12">
        <DockPanel LastChildFill="True">

            <!-- Заголовок -->
            <TextBlock Text="Выберите проект"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       DockPanel.Dock="Top"
                       Margin="0 0 0 12"/>

            <!-- Список проектов -->
            <ListBox ItemsSource="{Binding Projects}"
                     SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                     DockPanel.Dock="Top"
                     Height="220"
                     Background="#3c3f41"
                     BorderBrush="#555"
                     BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
                            <Path Data="M12,2 L2,7 L12,12 L22,7 Z"
                                  Fill="#cccccc"
                                  Width="16" Height="16"/>
                            <TextBlock Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Кнопки -->
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0 12 0 0">

                <Button Content="Удалить"
                        Command="{Binding RemoveCmd}"
                        MinWidth="90"/>
                <Button Content="Обновить"
                        Command="{Binding RefreshCmd}"
                        MinWidth="90"/>
                <Button Content="Отмена"
                        Command="{Binding CancelCmd}"
                        MinWidth="90"/>
                <Button Content="Открыть"
                        Command="{Binding OkCmd}"
                        MinWidth="110"
                        Background="#4caf50"
                        Foreground="White"/>
            </StackPanel>

        </DockPanel>
    </Border>
</Window>
