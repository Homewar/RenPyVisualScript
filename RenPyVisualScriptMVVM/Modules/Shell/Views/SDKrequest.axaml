<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:RenPyVisualScriptMVVM.Modules.Shell.ViewModels"
        xmlns:views="clr-namespace:RenPyVisualScriptMVVM.Modules.Shell.Views"
        mc:Ignorable="d"
        d:DesignWidth="720" d:DesignHeight="260"
        Width="720" Height="260"
        MinWidth="620" MinHeight="240"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        x:Class="RenPyVisualScriptMVVM.Modules.Shell.Views.SDKrequest"
        x:DataType="vm:SDKrequestViewModel"
        Title="Ren'Py SDK">
  <DockPanel>
        <views:CustomTitleBar DockPanel.Dock="Top"/>
  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="*,Auto">
    
    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
               FontSize="18" FontWeight="SemiBold"
               Text="Укажите путь к Ren'Py SDK" />

    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0"
               Opacity="0.8"
               TextWrapping="Wrap"
               Text="Это нужно один раз — чтобы запускать/собирать проекты и создавать шаблоны. Выберите папку SDK (где есть renpy.exe/renpy.sh, launcher и renpy)." />

    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="0,14,0,6"
               FontWeight="SemiBold"
               Text="Папка SDK:" />

    <TextBox Grid.Row="3" Grid.Column="0"
             Height="34"
             Watermark="Например: C:\RenPy\renpy-8.x.x-sdk"
             Text="{Binding Sdkpath, Mode=TwoWay}"
             VerticalContentAlignment="Center"/>

    <Button Grid.Row="3" Grid.Column="1" Margin="10,0,0,0"
            Height="34" MinWidth="110"
            Content="Обзор…"
            Command="{Binding BrowseCommand}" />

    <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Margin="0,10,0,0"
               Foreground="Tomato"
               TextWrapping="Wrap"
               IsVisible="{Binding HasError}"
               Text="{Binding ErrorText}" />

    <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,16,0,0"
                Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button Content="Отмена" MinWidth="110"
              IsVisible="{Binding CanCancel}"
              Command="{Binding CancelCommand}" />
      <Button Content="Сохранить" MinWidth="140"
              IsDefault="True"
              Command="{Binding SaveCommand}" />
    </StackPanel>

  </Grid>
  </DockPanel>
</Window>
