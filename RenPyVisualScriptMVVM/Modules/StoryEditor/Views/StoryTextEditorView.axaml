<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:vm="using:RenPyVisualScriptMVVM.Modules.StoryEditor.ViewModels"
             xmlns:models="using:RenPyVisualScriptMVVM.Modules.StoryEditor.Models"
             xmlns:graphModels="using:RenPyVisualScriptMVVM.Modules.GraphEditor.Models"
             x:Class="RenPyVisualScriptMVVM.Modules.StoryEditor.Views.StoryTextEditorView"
             x:DataType="vm:StoryTextEditorWindowViewModel"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="780"
             Background="#191a1b">

    <UserControl.Styles>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#15171B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2D323C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#1B1D22"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="#252934"/>
        </Style>

        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#2E405C"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="1"
              Background="#191a1b">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" MinWidth="8"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#15171B"
                    BorderBrush="#252932"
                    BorderThickness="0,0,1,0"
                    Padding="8">

                <Grid RowDefinitions="Auto,Auto,Auto,*"
                      RowSpacing="12">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto">
                        <TextBlock Text="Routes"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Column="1"
                                Background="#26354A"
                                CornerRadius="999"
                                Padding="8,3">
                            <TextBlock Text="{Binding Routes.Count}"
                                       Foreground="#8AB4F8"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#101113"
                            BorderBrush="#252932"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="6">
                        <ListBox ItemsSource="{Binding Routes}"
                                 SelectedItem="{Binding SelectedRoute, Mode=TwoWay}"
                                 MaxHeight="190"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="graphModels:StoryRoute">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#F3F3F3"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding NodeTitles.Count, StringFormat='{}{0} labels'}"
                                                   Foreground="#8AB4F8"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,Auto"
                          Margin="0,4,0,0">
                        <TextBlock Text="Route Labels"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Column="1"
                                Background="#26354A"
                                CornerRadius="999"
                                Padding="8,3">
                            <TextBlock Text="{Binding Labels.Count}"
                                       Foreground="#8AB4F8"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3"
                            Background="#101113"
                            BorderBrush="#252932"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="6">
                        <ListBox ItemsSource="{Binding Labels}"
                                 SelectedItem="{Binding SelectedLabel, Mode=TwoWay}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:StoryTextLabelItem">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#F3F3F3"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Text="{Binding FilePath}"
                                                       Foreground="#8B929E"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Spacing="2">
                                            <TextBlock Text="{Binding FragmentCount}"
                                                       Foreground="#8AB4F8"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"/>

                                            <TextBlock Text="{Binding Line, StringFormat='line {0}'}"
                                                       Foreground="#8B929E"
                                                       FontSize="11"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          MinWidth="4"
                          Background="#252932"
                          ResizeDirection="Columns"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <Grid Grid.Column="3"
                  RowDefinitions="*,240"
                  Background="#191a1b">
                <Border Grid.Row="0"
                        Background="#191a1b"
                        Padding="16">
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="10">
                        <Grid Grid.Row="0"
                              ColumnDefinitions="*,Auto,Auto,Auto">
                            <TextBlock Text="{Binding SelectedLabel.Name}"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="3"
                                    Background="#1E2A1F"
                                    BorderBrush="#335C36"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="10,4">
                                <TextBlock Text="Editable"
                                           Padding="0,3,0,0"
                                           Foreground="#81C784"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Column="2"
                                        Background="#1E2A1F"
                                        BorderBrush="#335C36"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,7"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock Text="Speaker"
                                                Foreground="#81C784"
                                                FontSize="13"
                                                VerticalAlignment="Center"/>

                                        <TextBlock Text="{Binding ActiveSpeakerCode}"
                                                Foreground="White"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                VerticalAlignment="Center"/>
                                    </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                        Background="#142235"
                                        BorderBrush="#263B59"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,7"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusText}"
                                            Foreground="#9CDCFE"
                                            FontSize="13"
                                            VerticalAlignment="Center"/>
                            </Border>

                        </Grid>

                        <Border Grid.Row="1"
                                Background="#101113"
                                BorderBrush="#252932"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="1">
                            <ae:TextEditor x:Name="StoryTextEditor"
                                           FontFamily="Consolas"
                                           FontSize="15"
                                           ShowLineNumbers="False"
                                           WordWrap="True"
                                           Background="#101113"
                                           Foreground="#F3F3F3"
                                           Padding="12"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#191a1b"
                        BorderBrush="#252932"
                        BorderThickness="0,1,0,0"
                        Padding="16">
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="10">
                        <Grid Grid.Row="0"
                              ColumnDefinitions="*,Auto">
                            <TextBlock Text="Source context"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                    Background="#142235"
                                    BorderBrush="#263B59"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="10,4">
                                <TextBlock Text="Read only"
                                           Foreground="#9CDCFE"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="#101113"
                                BorderBrush="#252932"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="1">
                            <ae:TextEditor x:Name="SourceContextEditor"
                                           IsReadOnly="True"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           ShowLineNumbers="False"
                                           WordWrap="True"
                                           Background="#101113"
                                           Foreground="#9CDCFE"
                                           Padding="10"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
