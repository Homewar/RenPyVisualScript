<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:vm="using:RenPyVisualScriptMVVM.Modules.StoryEditor.ViewModels"
        xmlns:models="using:RenPyVisualScriptMVVM.Modules.StoryEditor.Models"
        xmlns:graphModels="using:RenPyVisualScriptMVVM.Modules.GraphEditor.Models"
        x:Class="RenPyVisualScriptMVVM.Modules.StoryEditor.Views.StoryTextEditorWindow"
        x:DataType="vm:StoryTextEditorWindowViewModel"
        mc:Ignorable="d"
        Width="1280"
        Height="780"
        MinWidth="960"
        MinHeight="600"
        Background="#1e1e1e"
        Title="Story Text Editor">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" BorderBrush="#ea592a" BorderThickness="0,0,0,2" Padding="10,6">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Refresh" Command="{Binding RefreshCmd}" Padding="10,4"/>
                    <Button Content="Save document" Command="{Binding SaveAllCmd}" Padding="10,4"/>
                    <TextBlock Text="Speaker"
                               Foreground="#808080"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                    <ComboBox ItemsSource="{Binding SpeakerCodes}"
                              SelectedItem="{Binding ActiveSpeakerCode, Mode=TwoWay}"
                              MinWidth="160"
                              Padding="8,2"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding StatusText}"
                           Foreground="#9cdcfe"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="320,Auto,*">
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding Routes.Count, StringFormat='Routes ({0})'}"
                               Foreground="#d6d6d6"
                               FontSize="14"
                               Margin="10,8"/>
                    <ListBox DockPanel.Dock="Top"
                             ItemsSource="{Binding Routes}"
                             SelectedItem="{Binding SelectedRoute, Mode=TwoWay}"
                             Background="#1e1e1e"
                             BorderBrush="#3c3c3c"
                             BorderThickness="0,0,0,1"
                             MaxHeight="190">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="graphModels:StoryRoute">
                                <Grid ColumnDefinitions="*,Auto" Margin="8,5">
                                    <TextBlock Text="{Binding Name}" Foreground="#f3f3f3" FontSize="14"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding NodeTitles.Count, StringFormat='{}{0} labels'}"
                                               Foreground="#9cdcfe"
                                               FontSize="12"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding Labels.Count, StringFormat='Route Labels ({0})'}"
                               Foreground="#d6d6d6"
                               FontSize="14"
                               Margin="10,10,10,6"/>
                    <ListBox ItemsSource="{Binding Labels}"
                             SelectedItem="{Binding SelectedLabel, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:StoryTextLabelItem">
                                <Grid ColumnDefinitions="*,Auto" Margin="8,5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Foreground="#f3f3f3" FontSize="14"/>
                                        <TextBlock Text="{Binding FilePath}" Foreground="#808080" FontSize="11"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding FragmentCount}" Foreground="#9cdcfe" FontSize="12"/>
                                        <TextBlock Text="{Binding Line, StringFormat='line {0}'}" Foreground="#808080" FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          Background="#ea592a"
                          ResizeDirection="Columns"/>

            <Grid Grid.Column="2" RowDefinitions="*,260">
                <Border Grid.Row="0" Background="#1e1e1e" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="{Binding SelectedLabel.Name}"
                                   Foreground="#f3f3f3"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <Border Grid.Row="1"
                                Background="#202022"
                                BorderBrush="#3c3c3c"
                                BorderThickness="1">
                            <ae:TextEditor x:Name="StoryTextEditor"
                                           FontFamily="Consolas"
                                           FontSize="15"
                                           ShowLineNumbers="False"
                                           WordWrap="True"
                                           Background="#202022"
                                           Foreground="#f3f3f3"
                                           Padding="10"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1" BorderBrush="#3c3c3c" BorderThickness="0,1,0,0" Background="#252526" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="Source context"
                                   Foreground="#808080"
                                   FontSize="12"/>
                        <Border Grid.Row="1"
                                Background="#1e1e1e"
                                BorderBrush="#3c3c3c"
                                BorderThickness="1"
                                Margin="0,6,0,0">
                            <ae:TextEditor x:Name="SourceContextEditor"
                                           IsReadOnly="True"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           ShowLineNumbers="False"
                                           WordWrap="True"
                                           Background="#1e1e1e"
                                           Foreground="#9cdcfe"
                                           Padding="8"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
